# Copy this file to ".env" and fill in the keys you have.
# The app works in DEMO mode with no keys at all.

# SerpAPI (free tier ~100 searches/month) — https://serpapi.com
# Powers: Google Maps reviews (restaurants, hotels...) + Google Shopping product reviews
SERPAPI_KEY=

# Yelp Fusion API (free) — https://docs.developer.yelp.com
# Powers: restaurant/business ratings & review counts
YELP_API_KEY=

# Optional
PORT=3000
