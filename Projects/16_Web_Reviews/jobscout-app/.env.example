# Copy this file to ".env". JobScout works out of the box with ZERO keys —
# Arbeitnow's public job board API needs no signup at all.

# Optional: Adzuna (free, email signup only, no phone/card) - https://developer.adzuna.com/signup
# Broadens coverage beyond Arbeitnow's DACH (Germany/Austria/Switzerland) + remote-Europe focus
# to many more countries. Leave blank to run on Arbeitnow alone.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Optional
PORT=3001
# How long the fetched job pool stays cached before refetching (hours)
CACHE_TTL_HOURS=6
