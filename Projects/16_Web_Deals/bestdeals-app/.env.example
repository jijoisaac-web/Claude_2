# Copy this file to ".env" and fill in the keys you have.
# The app works in DEMO mode with no keys at all.

# eBay Browse API (free) — https://developer.ebay.com
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# Best Buy API (free, US only) — https://developer.bestbuy.com
BESTBUY_API_KEY=

# SerpAPI Google Shopping (free tier ~100 searches/month) — https://serpapi.com
SERPAPI_KEY=

# Optional
PORT=3000
